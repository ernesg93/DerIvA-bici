#!/bin/sh

set -eu

if [ "${UNIFICADORA_INTERNAL_TAG_PUSH:-0}" = "1" ]; then
  echo "[pre-push] Internal tag push detected, skipping release automation"
  exit 0
fi

echo "[pre-push] Generating pending release declaration"
npm run release:declare

declaration_file="releases/pending-release.md"

if [ -n "$(git status --porcelain -- "$declaration_file")" ]; then
  echo "[pre-push] Detected release declaration changes"
  git add "$declaration_file"

  if ! git diff --cached --quiet -- "$declaration_file"; then
    echo "[pre-push] Creating auto-commit for release declaration"
    ENGRAM_POST_COMMIT_AUTOCOMMIT=1 git commit -m "chore: update release declaration"
  fi
fi

echo "[pre-push] Publishing GitHub release from package.json version"
npm run release:publish -- "$@"
